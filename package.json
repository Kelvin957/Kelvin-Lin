{
  "name": "booking-platform",
  "version": "0.1.0",
  "private": true,
  "description": "中国市场预约小程序与管理后台后端（Node.js + MySQL）",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "node --test",
    "migrate": "tsx src/scripts/migrate.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "mysql2": "^3.14.5",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^24.3.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2",
    "tsx": "^4.20.5"
  }
}
